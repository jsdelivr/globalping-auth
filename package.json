	"scripts": {
		"build": "tsc && cp -r public dist",
		"coverage": "npm run clean && NODE_ENV=test c8 mocha",
		"clean": "rimraf coverage",
		"prepare": "husky || echo 'Failed to install husky'",
		"start": "ELASTIC_APM_CONFIG_FILE=elastic-apm-node.cjs node --experimental-loader elastic-apm-node/loader.mjs -r ./elastic-apm-utils.cjs -r elastic-apm-node/start.js dist/src/index.js",
		"start:dev": "NODE_ENV=development tsx src/index.ts",
		"start:test": "NODE_ENV=test knex migrate:latest && NODE_ENV=test tsx src/index.ts",
		"lint": "npm run lint:js && npm run lint:types",
		"lint:fix": "npm run lint:js:fix && npm run lint:types",
		"lint:js": "eslint --cache .",
		"lint:js:fix": "eslint --cache --fix .",
		"lint:types": "tsc --noEmit",
		"test": "npm run lint && npm run test:mocha",
		"test:dist": "node --test-reporter=spec test/dist.js",
		"test:mocha": "NODE_ENV=test mocha",
		"test:mocha:dev": "TS_NODE_TRANSPILE_ONLY=true NODE_ENV=test mocha"
	},
	"lint-staged": {
		"*.{cjs,js,json,ts}": "eslint --cache --fix"
	},
	"engines": {
		"node": "24"
	}
}
